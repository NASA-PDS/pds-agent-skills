# Emacs backup files
\#*#

# SonarCloud skill runtime outputs — export artifacts, not skill definitions
# These should be written to $OUTPUT_DIR (CWD or /tmp), never inside the skill dir
static/marketplace/skills/sonarcloud-security-exporting/*.json
static/marketplace/skills/sonarcloud-security-exporting/scripts/*.json
static/marketplace/skills/sonarcloud-security-exporting/scripts/*.txt
# Keep the intentional example file
!static/marketplace/skills/sonarcloud-security-exporting/examples/sonarcloud-export-example.json

# Root-level triage artifacts (generated by sonarcloud skills)
sonarcloud-triage-metrics.json
TRIAGE_METRICS.md

# Session artifacts
backup/
claude/

# Note: claude/summaries/ IS tracked (not ignored)
# This directory contains project summaries and documentation
